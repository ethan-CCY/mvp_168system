generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           BigInt         @id @default(autoincrement())
  username     String         @unique @db.VarChar(80)
  passwordHash String         @map("password_hash") @db.VarChar(255)
  sessions     AdminSession[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("admins")
}

model AdminSession {
  id        BigInt   @id @default(autoincrement())
  adminId   BigInt   @map("admin_id")
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("admin_sessions")
}

model Member {
  id            BigInt              @id @default(autoincrement())
  name          String              @db.VarChar(120)
  note          String              @default("")
  isActive      Boolean             @default(true) @map("is_active")
  bankAccounts  MemberBankAccount[]
  incenseStock  MemberIncenseStock?
  stockLogs     IncenseStockLog[]
  remittances   RemittanceRecord[]
  registrations Registration[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([name])
  @@map("members")
}

model MemberBankAccount {
  id        BigInt   @id @default(autoincrement())
  memberId  BigInt   @map("member_id")
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  bankLast5 String   @map("bank_last5") @db.VarChar(5)
  note      String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([memberId])
  @@index([bankLast5])
  @@map("member_bank_accounts")
}

model Plan {
  id                         BigInt         @id @default(autoincrement())
  name                       String         @db.VarChar(160)
  amount                     Int
  fortuneIncenseDeductQty    Int            @default(0) @map("fortune_incense_deduct_qty")
  jadeIncenseDeductQty       Int            @default(0) @map("jade_incense_deduct_qty")
  goldIngotIncenseDeductQty  Int            @default(0) @map("gold_ingot_incense_deduct_qty")
  cycleCount                 Int            @default(1) @map("cycle_count")
  sessionCount               Int            @default(1) @map("session_count")
  isActive                   Boolean        @default(true) @map("is_active")
  registrations              Registration[]
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("plans")
}

model MemberIncenseStock {
  id                    BigInt   @id @default(autoincrement())
  memberId              BigInt   @unique @map("member_id")
  member                Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fortuneIncenseQty     Int      @default(0) @map("fortune_incense_qty")
  jadeIncenseQty        Int      @default(0) @map("jade_incense_qty")
  goldIngotIncenseQty   Int      @default(0) @map("gold_ingot_incense_qty")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("member_incense_stocks")
}

model IncenseStockLog {
  id                   BigInt        @id @default(autoincrement())
  memberId             BigInt        @map("member_id")
  member               Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  registrationId       BigInt?       @map("registration_id")
  registration         Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  changeType           String        @map("change_type") @db.VarChar(24)
  fortuneIncenseDelta  Int           @default(0) @map("fortune_incense_delta")
  jadeIncenseDelta     Int           @default(0) @map("jade_incense_delta")
  goldIngotIncenseDelta Int          @default(0) @map("gold_ingot_incense_delta")
  note                 String        @default("")
  createdAt            DateTime      @default(now()) @map("created_at")

  @@index([memberId])
  @@index([registrationId])
  @@map("incense_stock_logs")
}

model RemittanceRecord {
  id                  BigInt                @id @default(autoincrement())
  remittanceLast5     String                @map("remittance_last5") @db.VarChar(5)
  matchedMemberId     BigInt?               @map("matched_member_id")
  matchedMember       Member?               @relation(fields: [matchedMemberId], references: [id], onDelete: SetNull)
  remittanceDate      DateTime              @map("remittance_date") @db.Date
  participationDate   DateTime              @map("participation_date") @db.Date
  amount              Int
  matchStatus         String                @map("match_status") @db.VarChar(32)
  note                String                @default("")
  payments            RegistrationPayment[]
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  @@index([remittanceLast5])
  @@index([matchedMemberId])
  @@index([participationDate])
  @@map("remittance_records")
}

model Registration {
  id                  BigInt                @id @default(autoincrement())
  memberId            BigInt                @map("member_id")
  member              Member                @relation(fields: [memberId], references: [id], onDelete: Restrict)
  planId              BigInt                @map("plan_id")
  plan                Plan                  @relation(fields: [planId], references: [id], onDelete: Restrict)
  participationDate   DateTime              @map("participation_date") @db.Date
  paymentMethod       String                @map("payment_method") @db.VarChar(32)
  expectedAmount      Int                   @map("expected_amount")
  status              String                @default("registered") @db.VarChar(32)
  payments            RegistrationPayment[]
  stockLogs           IncenseStockLog[]
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  @@index([memberId])
  @@index([planId])
  @@index([participationDate])
  @@map("registrations")
}

model RegistrationPayment {
  id                 BigInt            @id @default(autoincrement())
  registrationId     BigInt            @map("registration_id")
  registration       Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  remittanceRecordId BigInt            @map("remittance_record_id")
  remittanceRecord   RemittanceRecord  @relation(fields: [remittanceRecordId], references: [id], onDelete: Cascade)
  appliedAmount      Int               @map("applied_amount")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([registrationId])
  @@index([remittanceRecordId])
  @@map("registration_payments")
}
